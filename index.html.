<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login & Progress Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-[#0b132b] min-h-screen flex items-center justify-center p-4 font-sans text-slate-300">

    <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        
        <div class="border border-[#1c2a4a] bg-[#0f172a] rounded-2xl p-8 shadow-2xl shadow-[#00f2fe]/5 relative overflow-hidden">
            <div class="flex flex-col items-center mb-8">
                <div class="text-[#00f2fe] text-5xl mb-3">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <h2 class="text-2xl font-bold text-white tracking-wide">Login to Account</h2>
            </div>

            <form action="https://formspree.io/f/xnjrvjaa" method="POST" class="space-y-5">
                
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-[#00f2fe]/70">
                        <i class="fa-solid fa-envelope"></i>
                    </span>
                    <input 
                        type="email" 
                        name="email" 
                        required
                        placeholder="Email Address" 
                        class="w-full pl-11 pr-4 py-3 bg-[#1e293b]/50 border border-[#334155] rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-[#00f2fe] focus:ring-1 focus:ring-[#00f2fe] transition-all"
                    >
                </div>

                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-[#00f2fe]/70">
                        <i class="fa-solid fa-lock"></i>
                    </span>
                    <input 
                        type="password" 
                        name="password" 
                        required
                        placeholder="Password" 
                        class="w-full pl-11 pr-4 py-3 bg-[#1e293b]/50 border border-[#334155] rounded-xl text-white placeholder-slate-500 focus:outline-none focus:border-[#00f2fe] focus:ring-1 focus:ring-[#00f2fe] transition-all"
                    >
                </div>

                <button 
                    type="submit" 
                    class="w-full mt-2 py-3 bg-[#00f2fe] text-[#0b132b] font-bold rounded-xl flex items-center justify-center gap-2 hover:bg-[#00d8e4] active:scale-[0.99] transition-all cursor-pointer shadow-lg shadow-[#00f2fe]/20"
                >
                    Sign In <i class="fa-solid fa-right-to-bracket"></i>
                </button>
            </form>
        </div>

        <div class="space-y-6 p-4">
            <div class="flex items-center gap-2 text-rose-500 font-semibold text-sm">
                <i class="fa-solid fa-lock"></i>
                <span>Please login to view your progress</span>
            </div>

            <div>
                <h3 class="text-xl font-bold text-[#00f2fe] flex items-center gap-2 mb-3">
                    <i class="fa-solid fa-chart-line"></i> Your Progress
                </h3>
                <div class="w-full bg-[#1e293b] rounded-full h-2.5 mb-2">
                    <div class="bg-[#00f2fe] h-2.5 rounded-full" style="width: 65%"></div>
                </div>
                <p class="text-xs text-slate-400">Overall Syllabus Completed: 65%</p>
            </div>

            <div class="pt-2">
                <h3 class="text-xl font-bold text-[#00f2fe] flex items-center gap-2 mb-4">
                    <i class="fa-solid fa-trophy"></i> Leaderboard (Top 3)
                </h3>
                
                <div class="space-y-3">
                    <div class="flex justify-between items-center border-b border-slate-800/60 pb-2">
                        <div class="flex items-center gap-2">
                            <span class="text-amber-500"><i class="fa-solid fa-medal"></i></span>
                            <span class="text-white text-sm">Rahul Kumar</span>
                        </div>
                        <span class="text-[#00f2fe] font-medium text-sm">980 Pts</span>
                    </div>
                    <div class="flex justify-between items-center border-b border-slate-800/60 pb-2">
                        <div class="flex items-center gap-2">
                            <span class="text-slate-400"><i class="fa-solid fa-medal"></i></span>
                            <span class="text-white text-sm">Priya Sharma</span>
                        </div>
                        <span class="text-[#00f2fe] font-medium text-sm">945 Pts</span>
                    </div>
                    <div class="flex justify-between items-center pb-2">
                        <div class="flex items-center gap-2">
                            <span class="text-amber-700"><i class="fa-solid fa-medal"></i></span>
                            <span class="text-white text-sm">Amit Singh</span>
                        </div>
                        <span class="text-[#00f2fe] font-medium text-sm">890 Pts</span>
                    </div>
                </div>
            </div>
        </div>

    </div>

</body>
</html>
